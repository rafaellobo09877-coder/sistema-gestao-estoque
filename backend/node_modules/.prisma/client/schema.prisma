generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("admin")
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  movements    Movement[]
  imports      StockImport[]
}

model Product {
  id              Int            @id @default(autoincrement())
  itemCode        String         @unique
  materialName    String
  unitMeasure     String?
  purchasePurpose String?
  directorate     String?
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  monthlyStocks   MonthlyStock[]
  movements       Movement[]
  stockAlerts     StockAlert[]
}

model StockImport {
  id              Int            @id @default(autoincrement())
  referenceMonth  Int
  referenceYear   Int
  fileName        String
  warehouse       String?
  organization    String?
  reportDate      DateTime?
  totalStockValue Float?
  importedById    Int?
  importedAt      DateTime       @default(now())
  status          String         @default("confirmed")
  importedBy      User?          @relation(fields: [importedById], references: [id])
  stocks          MonthlyStock[]

  @@unique([referenceMonth, referenceYear, warehouse])
}

model MonthlyStock {
  id                 Int         @id @default(autoincrement())
  importId           Int
  productId          Int
  reservedQty        Float       @default(0)
  reservedValue      Float       @default(0)
  availableQty       Float       @default(0)
  availableValue     Float       @default(0)
  totalQty           Float       @default(0)
  totalValue         Float       @default(0)
  unitEstimatedValue Float?
  expiry             String?
  stockImport        StockImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  product            Product     @relation(fields: [productId], references: [id])

  @@unique([importId, productId])
}

model Movement {
  id             Int      @id @default(autoincrement())
  productId      Int
  referenceMonth Int
  referenceYear  Int
  type           String
  quantity       Float
  movementDate   DateTime
  note           String?
  userId         Int?
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])
}

model StockAlert {
  id         Int     @id @default(autoincrement())
  productId  Int
  minimumQty Float   @default(10)
  active     Boolean @default(true)
  product    Product @relation(fields: [productId], references: [id])
}
